-- Para autofarm: ejemplo base seguro (usa los remotes extraídos)
-- Ajusta según tu juego. Siempre con randomization y checks.
local function safeAutoFarm(remoteName, args)
    pcall(function()
        local remote = game:FindFirstChild(remoteName, true) or nil
        if remote and remote:IsA("RemoteEvent") then
            wait(math.random(0.5, 1.5)) -- human delay
            remote:FireServer(unpack(args))
        end
    end)
end

