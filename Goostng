-- Buscar Remotes y Bindables de forma segura (para autofarm futuro)
extractData.Remotes = {}
pcall(function()
    for _, obj in ipairs(game:GetDescendants()) do
        if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") or obj:IsA("BindableEvent") then
            table.insert(extractData.Remotes, {
                Name = obj.Name,
                Class = obj.ClassName,
                ParentPath = obj:GetFullName()
            })
        end
    end
end)

-- Dump a JSON-like para análisis (fácil de copiar o guardar)
local function tableToString(t, indent)
    indent = indent or ""
    local str = "{\n"
    for k, v in pairs(t) do
        local key = type(k) == "string" and '"'..k..'"' or k
        if type(v) == "table" then
            str = str .. indent .. "  " .. key .. " = " .. tableToString(v, indent .. "  ") .. ",\n"
        else
            local val = type(v) == "string" and '"'..v..'"' or tostring(v)
            str = str .. indent .. "  " .. key .. " = " .. val .. ",\n"
        end
    end
    return str .. indent .. "}"
end

