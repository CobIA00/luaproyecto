[GROK-RAW] -- Extractor Total Seguro para Delta Executor

local player = game.Players.LocalPlayer
local extractData = {}

-- Función segura para deep scan de instancias (evita crashes y detección)
local function safeDeepScan(parent, maxDepth, currentDepth)
    currentDepth = currentDepth or 0
    if currentDepth > maxDepth then return end
    pcall(function()
        for _, child in ipairs(parent:GetChildren()) do
            local entry = {
                Name = child.Name,
                ClassName = child.ClassName,
                Properties = {}
            }
            -- Extraer propiedades comunes de forma segura
            pcall(function()
                for _, prop in ipairs({"Value", "Text", "Position", "Size", "Enabled", "Visible"}) do
                    if pcall(function() return child[prop] end) then
                        entry.Properties[prop] = tostring(child[prop])
                    end
                end
            end)
            if child:IsA("ValueBase") then
                entry.Value = child.Value
            end
            if not extractData[parent.ClassName] then extractData[parent.ClassName] = {} end
            table.insert(extractData[parent.ClassName], entry)
            safeDeepScan(child, maxDepth, currentDepth + 1)
        end
    end)
end

-- Extraer info del jugador y stats
pcall(function()
    extractData.PlayerInfo = {
        UserId = player.UserId,
        Name = player.Name,
        DisplayName = player.DisplayName,
        Team = player.Team and player.Team.Name or "None",
        Character = player.Character and player.Character.Name or "No Character"
    }
    
    -- Stats comunes en juegos (ajusta según el juego)
    extractData.Stats = {}
    for _, v in ipairs(game:GetDescendants()) do
        pcall(function()
            if v:IsA("IntValue") or v:IsA("NumberValue") or v:IsA("StringValue") then
                if v.Parent and (v.Parent == player or v.Parent.Parent == player) then
                    extractData.Stats[v.Name] = v.Value
                end
            end
        end)
    end
end)

