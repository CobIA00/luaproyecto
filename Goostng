local caps = checkDeltaCapabilities()

-- 3.1 通过GC扫描获取隐藏数据（如果可用）
if caps.getgc then
    extractData.GCData = {}
    pcall(function()
        humanDelay(0.2, 0.4)
        local gcObjects = getgc(true)
        local count = 0
        local maxObjects = 500  -- 限制数量防止崩溃
        
        for i, obj in ipairs(gcObjects) do
            if count >= maxObjects then break end
            pcall(function()
                local objType = typeof(obj)
                if objType == "table" then
                    -- 尝试提取表的关键信息
                    local keys = {}
                    for k, v in pairs(obj) do
                        if type(k) == "string" and #keys < 20 then
                            table.insert(keys, k)
                        end
                    end
                    if #keys > 0 then
                        count = count + 1
                        table.insert(extractData.GCData, {
                            Type = "Table",
                            Keys = keys,
                            Size = #keys
                        })
                    end
                elseif objType == "function" then
                    -- 记录函数信息
                    local info = debug.getinfo(obj, "nS")
                    if info and info.name then
                        count = count + 1
                        table.insert(extractData.GCData, {
                            Type = "Function",
                            Name = info.name,
                            Source = info.source
                        })
                    end
                elseif objType == "userdata" then
                    -- 用户数据（通常包含重要对象）
                    pcall(function()
                        if obj.ClassName then
                            count = count + 1
                            table.insert(extractData.GCData, {
                                Type = "Userdata",
                                Class = obj.ClassName,
                                Name = obj.Name or "Unknown"
                            })
                        end
                    end)
                end
            end)
        end
        extractData.Meta.GCObjectsScanned = count
    end)
end

