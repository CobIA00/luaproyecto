-- 1. 等待游戏完全加载，避免 LocalPlayer 为 nil
if not game:IsLoaded() then
    game.Loaded:Wait()
end

-- 2. 安全等待 LocalPlayer 出现（部分游戏需要角色加载后才可用）
local player = nil
repeat
    task.wait(0.5)
    player = game:GetService("Players").LocalPlayer
until player

print("✅ 玩家已加载: " .. player.Name)

-- 以下为完整提取器代码（已包含之前的安全措施，无需修改）
-- ============================================================
local CONFIG = {
    MaxDepth = 3,
    SafeMode = true,
    RandomizeDelays = true,
    UseDeltaFeatures = true
}

local SafeUtils = {}
function SafeUtils:SafeCall(func, ...)
    local success, result = pcall(func, ...)
    return success, result
end

function SafeUtils:HumanDelay(baseDelay)
    if not CONFIG.RandomizeDelays then
        task.wait(baseDelay or 0.5)
        return
    end
    local minDelay = baseDelay and (baseDelay * 0.8) or 0.4
    local maxDelay = baseDelay and (baseDelay * 1.5) or 0.8
    task.wait(minDelay + math.random() * (maxDelay - minDelay))
end

-- 主提取器对象
local Extractor = {
    Data = {
        PlayerInfo = {},
        Remotes = {},
        GameStructure = {},
        Stats = {}
    }
}

-- 安全提取玩家信息
SafeUtils:SafeCall(function()
    local info = {
        UserId = player.UserId,
        Name = player.Name,
        DisplayName = player.DisplayName,
        Team = player.Team and player.Team.Name or "None",
        Character = player.Character and player.Character.Name or "无角色"
    }
    Extractor.Data.PlayerInfo = info
    print("📋 玩家信息已提取")
end)

-- 提取所有 RemoteEvent / RemoteFunction / BindableEvent
SafeUtils:SafeCall(function()
    local remotes = {}
    for _, obj in ipairs(game:GetDescendants()) do
        if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") or obj:IsA("BindableEvent") then
            table.insert(remotes, {
                Name = obj.Name,
                Class = obj.ClassName,
                Path = obj:GetFullName()
            })
        end
    end
    Extractor.Data.Remotes = remotes
    print("📡 找到 " .. #remotes .. " 个远程事件")
end)

-- 提取常用属性（示例：仅提取 Workspace 第一层结构）
SafeUtils:SafeCall(function()
    local workspaceChildren = {}
    for _, child in ipairs(workspace:GetChildren()) do
        table.insert(workspaceChildren, child.Name .. " [" .. child.ClassName .. "]")
    end
    Extractor.Data.GameStructure.WorkspaceChildren = workspaceChildren
end)

-- 输出结果
print("=== 数据提取完成 ===")
print("玩家: " .. Extractor.Data.PlayerInfo.Name)
print("远程事件数量: " .. #Extractor.Data.Remotes)

-- 将数据存入全局变量，供后续脚本使用
getgenv().ExtractedData = Extractor.Data
print("💾 数据已保存至全局变量 'ExtractedData'，可在其他脚本中直接调用。")
