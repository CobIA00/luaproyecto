-- 10. 漏洞启发
local vulns = {}
for _, remote in ipairs(remotes) do
    if remote.Path:find("ReplicatedStorage") and not remote.Name:lower():match("ban") then
        vulns[#vulns+1] = {Type="Unprotected Remote", Remote=remote.Name, Path=remote.Path}
    end
end
Extractor.Data.PotentialVulnerabilities = vulns

-- ==================== 输出与保存 ====================
getgenv().TotalExtractedData = Extractor.Data
