local CONFIG = {
    MaxDepth = 5,
    ExtractSource = true,            -- 提取脚本源码
    ExtractCoreGui = true,           -- 提取 CoreGui 内容（可能含反作弊UI）
    ExtractLoadedModules = true,     -- 提取所有已加载模块源码（需 getloadedmodules）
    ExtractGCTable = true,           -- 提取全局表信息（需 getgc）
    ExtractPhysicsDetails = true,    -- 提取 Workspace 内所有部件的碰撞属性
    WriteToFile = true,              -- 保存为文件（需 writefile 支持）
    OutputJSON = true
}

-- ==================== 安全工具 ====================
local Safe = {}
function Safe:pcall(...)
    local s, r = pcall(...)
    return s, r
end
function Safe:serialize(v, depth)
    depth = depth or 0
    if depth > 5 then return "[MaxDepth]" end
    local t = type(v)
    if t == "string" or t == "number" or t == "boolean" then
        return v
    elseif t == "table" then
        local out = {}
        for k, val in pairs(v) do
            out[tostring(k)] = Safe:serialize(val, depth + 1)
        end
        return out
    elseif t == "userdata" or t == "function" then
        return tostring(v)
    else
        return nil
    end
end

-- 获取源码（适配 Delta）
function Safe:getScriptSource(scriptObj)
    if not CONFIG.ExtractSource then return nil end
    local src = nil
    Safe:pcall(function()
        if getsource then src = getsource(scriptObj)
        elseif getscriptclosure then
            local f = getscriptclosure(scriptObj)
            if debug and debug.getinfo then
                src = debug.getinfo(f, "S").source
            end
        elseif scriptObj.Source then src = scriptObj.Source
        end
    end)
    return src
end

-- ==================== 主提取器 ====================
