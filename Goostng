-- 5. 服务结构扫描（增强）
local services = {}
local allServices = {
    "Workspace", "ReplicatedStorage", "ReplicatedFirst", "Players",
    "Lighting", "SoundService", "StarterGui", "StarterPlayer",
    "StarterPack", "StarterCharacter", "PhysicsService", "UserInputService",
    "ContextActionService", "TweenService", "MarketplaceService",
    "TeleportService", "RunService", "HttpService", "Chat", "LocalizationService"
}

local function deepScan(obj, depth)
    if depth > CONFIG.MaxDepth then return nil end
    local node = {Name=obj.Name, Class=obj.ClassName, Children={}}
    if obj:IsA("Script") or obj:IsA("LocalScript") or obj:IsA("ModuleScript") then
        node.Source = Safe:getScriptSource(obj)
    end
    -- 物理属性（仅对 BasePart）
    if CONFIG.ExtractPhysicsDetails and obj:IsA("BasePart") then
        node.Physics = {
            CanCollide = obj.CanCollide,
            Massless = obj.Massless,
            CollisionGroupId = obj.CollisionGroupId,
            Transparency = obj.Transparency,
            Anchored = obj.Anchored
        }
    end
    for _, child in ipairs(obj:GetChildren()) do
        local c = deepScan(child, depth+1)
        if c then table.insert(node.Children, c) end
    end
    return node
end

for _, sName in ipairs(allServices) do
    Safe:pcall(function()
        local srv = game:GetService(sName)
        if srv then
            services[sName] = deepScan(srv, 0)
        end
    end)
end
Extractor.Data.Services = services

-- 6. CoreGui 提取（需保护）
if CONFIG.ExtractCoreGui then
    Safe:pcall(function()
        local coreGui = game:GetService("CoreGui")
        Extractor.Data.CoreGui = deepScan(coreGui, 0)
    end)
end

-- 7. 已加载模块（需 getloadedmodules）
if CONFIG.ExtractLoadedModules then
    Extractor.Data.LoadedModules = {}
    Safe:pcall(function()
        if getloadedmodules then
            local modules = getloadedmodules()
            for _, mod in ipairs(modules) do
                table.insert(Extractor.Data.LoadedModules, {
                    Name = mod.Name,
                    Source = Safe:getScriptSource(mod)
                })
            end
        end
    end)
end

-- 8. 全局表（需 getgc）
if CONFIG.ExtractGCTable then
    Extractor.Data.GlobalTables = {}
    Safe:pcall(function()
        if getgc then
            local gc = getgc()
            for _, obj in ipairs(gc) do
                if type(obj) == "table" then
                    local summary = {}
                    for k, v in pairs(obj) do
                        if type(v) ~= "function" then
                            summary[tostring(k)] = Safe:serialize(v, 2)
                        else
                            summary[tostring(k)] = "[Function]"
                        end
                        if #summary > 10 then break end
                    end
                    table.insert(Extractor.Data.GlobalTables, summary)
                end
            end
        end
    end)
end

