-- ==================== 第四部分：智能自动化基础框架 ====================
extractData.AutomationFramework = {
    -- 安全调用远程事件
    FireRemote = function(remotePath, ...)
        local success, result = pcall(function()
            local remote = game:GetService("ReplicatedStorage"):FindFirstChild(remotePath, true)
            if not remote then
                remote = game:GetService("Workspace"):FindFirstChild(remotePath, true)
            end
            
            if remote and remote:IsA("RemoteEvent") then
                humanDelay(0.3, 0.8)
                remote:FireServer(...)
                return true
            end
            return false
        end)
        return success and result
    end,
    
    -- 安全调用远程函数
    InvokeRemote = function(remotePath, ...)
        local success, result = pcall(function()
            local remote = game:GetService("ReplicatedStorage"):FindFirstChild(remotePath, true)
            if not remote then
                remote = game:GetService("Workspace"):FindFirstChild(remotePath, true)
            end
            
            if remote and remote:IsA("RemoteFunction") then
                humanDelay(0.3, 0.8)
                return remote:InvokeServer(...)
            end
            return nil
        end)
        return success and result
    end,
    
    -- 自动识别可能的自动化目标
    SuggestAutomation = function()
        local suggestions = {}
        
        -- 根据远程事件名称推荐自动化
        for _, remote in ipairs(extractData.Remotes.Events) do
            local name = remote.Name:lower()
            if name:find("collect") or name:find("pickup") then
                table.insert(suggestions, {Type = "Collect", Remote = remote.Name})
            elseif name:find("attack") or name:find("damage") then
                table.insert(suggestions, {Type = "Combat", Remote = remote.Name})
            elseif name:find("buy") or name:find("purchase") then
                table.insert(suggestions, {Type = "Shop", Remote = remote.Name})
            elseif name:find("equip") or name:find("unequip") then
                table.insert(suggestions, {Type = "Inventory", Remote = remote.Name})
            end
        end
        
        return suggestions
    end
}

