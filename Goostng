-- 智能表转字符串（美化版）
local function beautifyTable(t, indent, maxDepth, currentDepth)
    indent = indent or ""
    maxDepth = maxDepth or 5
    currentDepth = currentDepth or 0
    
    if currentDepth > maxDepth then
        return '"..."'
    end
    
    if type(t) ~= "table" then
        if type(t) == "string" then
            return string.format("%q", t)
        else
            return tostring(t)
        end
    end
    
    local result = {}
    table.insert(result, "{")
    
    for k, v in pairs(t) do
        local formattedKey = type(k) == "string" and string.format("[%q]", k) or "[" .. tostring(k) .. "]"
        local formattedValue = beautifyTable(v, indent .. "  ", maxDepth, currentDepth + 1)
        table.insert(result, indent .. "  " .. formattedKey .. " = " .. formattedValue .. ",")
    end
    
    table.insert(result, indent .. "}")
    return table.concat(result, "\n")
end

-- 创建数据存储（隐藏位置）
local function createDataStorage(data)
    local success, result = pcall(function()
        -- 使用更隐蔽的存储位置
        local storage = Instance.new("Folder")
        storage.Name = "HS_" .. tostring(math.random(10000, 99999))
        storage.Parent = game:GetService("CoreGui")  -- CoreGui更难被检测
        
        local stringValue = Instance.new("StringValue")
        stringValue.Name = "data"
        stringValue.Value = data
        stringValue.Parent = storage
        
        return storage
    end)
    
    return success and result or nil
end

