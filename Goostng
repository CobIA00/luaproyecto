-- 安全函数：检测Delta执行器特殊功能可用性
local function checkDeltaCapabilities()
    local caps = {
        getgc = false,
        getconnections = false,
        getloadedmodules = false,
        getgenv = false,
        getsenv = false,
        hookfunction = false,
        getrawmetatable = false
    }
    
    -- 安全检测每个功能
    pcall(function() if getgc then caps.getgc = true end end)
    pcall(function() if getconnections then caps.getconnections = true end end)
    pcall(function() if getloadedmodules then caps.getloadedmodules = true end end)
    pcall(function() if getgenv then caps.getgenv = true end end)
    pcall(function() if getsenv then caps.getsenv = true end end)
    pcall(function() if hookfunction then caps.hookfunction = true end end)
    pcall(function() if getrawmetatable then caps.getrawmetatable = true end end)
    
    extractData.Meta.Capabilities = caps
    return caps
end

-- 安全函数：随机延迟（模拟人类行为）
local function humanDelay(minDelay, maxDelay)
    minDelay = minDelay or 0.05
    maxDelay = maxDelay or 0.2
    wait(math.random(minDelay * 100, maxDelay * 100) / 100)
end

-- 安全函数：深度扫描（优化版 - 限制范围并过滤不必要对象）
local function smartDeepScan(root, options)
    options = options or {}
    local maxDepth = options.maxDepth or 3
    local maxChildren = options.maxChildren or 50
    local includeClasses = options.includeClasses or {}
    local excludeClasses = options.excludeClasses or {
        "ParticleEmitter", "Trail", "Beam", "Sound", "Decal", "Texture",
        "UIStroke", "UIGradient", "UIPadding", "UIScale"
    }
    
    local result = {}
    local function scan(parent, depth)
        if depth > maxDepth then return end
        
        local children = parent:GetChildren()
        local count = 0
        
        for _, child in ipairs(children) do
            if count >= maxChildren then break end
            
            -- 过滤不重要的类
            if not table.find(excludeClasses, child.ClassName) then
                count = count + 1
                
                local node = {
                    Name = child.Name,
                    Class = child.ClassName,
                    Depth = depth
                }
                
                -- 根据类类型提取特定属性
                if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
                    node.Type = "Remote"
                    node.Path = child:GetFullName()
                elseif child:IsA("BindableEvent") or child:IsA("BindableFunction") then
                    node.Type = "Bindable"
                    node.Path = child:GetFullName()
                elseif child:IsA("ModuleScript") then
                    node.Type = "Module"
                elseif child:IsA("LocalScript") or child:IsA("Script") then
                    node.Type = "Script"
                    -- 尝试获取脚本源码（如果环境允许）
                    pcall(function()
                        if getsenv and child:IsA("LocalScript") then
                            local env = getsenv(child)
                            if env then
                                node.HasEnvironment = true
                            end
                        end
                    end)
                elseif child:IsA("Model") or child:IsA("Folder") then
                    node.Type = "Container"
                    node.Children = {}
                    scan(child, depth + 1)
                elseif child:IsA("BasePart") then
                    node.Type = "Part"
                    node.Position = tostring(child.Position)
                    node.Size = tostring(child.Size)
                    node.Transparency = child.Transparency
                    node.CanCollide = child.CanCollide
                    node.Anchored = child.Anchored
                elseif child:IsA("ValueBase") then
                    node.Type = "Value"
                    pcall(function() node.Value = child.Value end)
                end
                
                table.insert(result, node)
            end
        end
    end
    
    scan(root, 0)
    return result
end

