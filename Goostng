end

-- 写入文件（需 writefile 支持）
if CONFIG.WriteToFile then
    Safe:pcall(function()
        if writefile then
            local json = game:GetService("HttpService"):JSONEncode(Safe:serialize(Extractor.Data))
            local filename = "DeltaExtract_" .. game.PlaceId .. "_" .. os.time() .. ".json"
            writefile(filename, json)
            print("📄 数据已写入文件: " .. filename)
        end
    end)
end

